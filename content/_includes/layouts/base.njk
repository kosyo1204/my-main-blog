{#
  base.njk: ページ共通レイアウト
  
  Purpose: すべてのページの基本的な HTML 構造を提供
  - HTML 骨組み (<!DOCTYPE>, <head>, <body>)
  - Meta タグ (viewport, charset, SEO)
  - ヘッダー (サイトタイトル、ナビゲーション)
  - フッター (著作権表記)
  - GA4 計測タグ (条件付き)
  
  Usage:
    ---
    layout: base
    title: "ページタイトル"
    ---
    
    <h1>見出し</h1>
    <p>本文</p>
#}
{%- set site = site | default({}) -%}
<!DOCTYPE html>
<html lang="{{ site.locale | default('ja-JP') }}">
<head>
  <!-- ========== メタ情報 ========== -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page.excerpt or site.description or '' }}">
  <meta name="theme-color" content="#ffffff">
  
  <!-- ========== SEO ========== -->
  <!-- 注: SEO メタタグ詳細は seo.njk に分離（T006 で実装） -->
  <title>
    {%- if category -%}
      カテゴリー - {{ category }} | {{ site.title }}
    {%- elif tag -%}
      タグ - {{ tag }} | {{ site.title }}
    {%- elif page.title or title -%}
      {{ page.title or title }} | {{ site.title }}
    {%- else -%}
      {{ site.title }}
    {%- endif -%}
  </title>

  <!-- ========== Google Fonts ========== -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Literata:opsz,wght@7..72,400;7..72,600;7..72,700&display=swap" rel="stylesheet">

  <!-- ========== スタイル ========== -->
  <link rel="stylesheet" href="{{ '/css/site.css' | url }}">

  <!-- フォーカス可視化（アクセシビリティ） -->
  <style>
    /* フォーカス表示の視認性向上（FR-023: キーボード操作で到達可能） */
    :focus-visible {
      outline: 2px solid var(--color-primary-700);
      outline-offset: 2px;
    }
  </style>
</head>

<body>
  <!-- スキップリンク（アクセシビリティ: キーボードユーザーがナビをスキップ） -->
  <a href="#main-content" class="sr-only">メインコンテンツへスキップ</a>

  <!-- ========== ヘッダー ========== -->
  <header role="banner">
    <div class="container">
      <div class="header-content">
        <!-- ロゴ / サイトタイトル（各ページの h1 が主見出し） -->
        <div class="site-title">
          <a href="{{ '/' | url }}" title="{{ site.title }}">
            {{ site.title }}
          </a>
        </div>
        
        <!-- サブタイトル/説明 -->
        {%- if site.description %}
        <p class="site-description">{{ site.description }}</p>
        {%- endif %}
      </div>

      <!-- ========== ナビゲーション ========== -->
      <!-- 実装: T007 で navigation.json から動的に生成 -->
      <nav role="navigation" aria-label="Main navigation" data-testid="main-nav">
        <button class="menu-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="メニュー">
          <span class="hamburger-icon">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <ul id="nav-menu" class="nav-menu" aria-hidden="true">
          <li><a href="{{ '/' | url }}">ホーム</a></li>
          <li><a href="{{ '/tags/' | url }}">タグ</a></li>
          <li><a href="{{ '/categories/' | url }}">カテゴリー</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- ========== メインコンテンツ ========== -->
  <main id="main-content" role="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <!-- ========== フッター ========== -->
  <footer role="contentinfo">
    <div class="container footer-content">
      <p>
        &copy; 2026 {{ site.author or site.title }}.
        All rights reserved.
      </p>
      <p class="footer-note">
        Powered by <a href="https://www.11ty.dev/" target="_blank" rel="noopener">Eleventy</a> &amp;
        hosted on <a href="https://pages.github.com/" target="_blank" rel="noopener">GitHub Pages</a>
      </p>
    </div>
  </footer>

  <!-- ========== GA4 計測タグ（条件付き） ========== -->
  {%- include "ga4.njk" %}

  <!-- ========== RUM イベント（GA4 の後に読込） ========== -->
  {%- include "rum-events.njk" %}

  <!-- ========== モバイルナビゲーション JavaScript ========== -->
  <script>
    (function() {
      // ブレークポイント定数（CSSのメディアクエリと合わせる）
      const MOBILE_MAX_WIDTH = 768;
      const menuToggle = document.querySelector('.menu-toggle');
      const navMenu = document.querySelector('.nav-menu');

      if (!menuToggle || !navMenu) return;

      // 現在のビューポートがデスクトップかを判定
      function isDesktopViewport() {
        return window.innerWidth > MOBILE_MAX_WIDTH;
      }

      // 前回のビューポート状態を保持（リサイズ時のレース条件回避に利用）
      let wasDesktopViewport = isDesktopViewport();

      // 初期化：デスクトップでは常時表示、モバイルではクローズ状態に揃える
      function initMenuState(forceCloseOnMobile) {
        if (isDesktopViewport()) {
          navMenu.setAttribute('aria-hidden', 'false');
          menuToggle.setAttribute('aria-expanded', 'false');
          return;
        }

        if (forceCloseOnMobile) {
          closeMenu();
        }
      }

      // 初期状態を設定
      initMenuState(true);

      function openMenu() {
        menuToggle.setAttribute('aria-expanded', 'true');
        navMenu.setAttribute('aria-hidden', 'false');
      }

      function toggleMenu() {
        // デスクトップではトグル動作を行わない
        if (isDesktopViewport()) {
          return;
        }

        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          closeMenu();
        } else {
          openMenu();
        }
      }

      function closeMenu() {
        menuToggle.setAttribute('aria-expanded', 'false');
        navMenu.setAttribute('aria-hidden', 'true');
      }

      // ハンバーガーメニュークリック
      menuToggle.addEventListener('click', toggleMenu);

      // Escキーでメニューを閉じる
      document.addEventListener('keydown', function(e) {
        if (!isDesktopViewport() && e.key === 'Escape') {
          closeMenu();
        }
      });

      // メニュー外クリックで閉じる
      document.addEventListener('click', function(e) {
        if (isDesktopViewport()) {
          return;
        }

        const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
        if (isOpen && !menuToggle.contains(e.target) && !navMenu.contains(e.target)) {
          closeMenu();
        }
      });

      // ナビゲーションリンククリックでメニューを閉じる（モバイルのみ）
      const navLinks = navMenu.querySelectorAll('a');
      navLinks.forEach(function(link) {
        link.addEventListener('click', function() {
          if (!isDesktopViewport()) {
            closeMenu();
          }
        });
      });

      // ウィンドウリサイズ時は「ブレークポイントを跨いだときだけ」状態をリセット
      let resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          const isDesktopNow = isDesktopViewport();
          if (isDesktopNow !== wasDesktopViewport) {
            initMenuState(true);
            wasDesktopViewport = isDesktopNow;
          }
        }, 250);
      });
    })();
  </script>
</body>
</html>
